# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (mode test)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Webhook clé partagée pipeline AltiMetrix
ALTIMETRIX_WEBHOOK_KEY=

# Resend (emails transactionnels)
RESEND_API_KEY=

# Plausible Analytics (privacy-first)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=altimetrix.fr

# Cloudflare R2 (stockage photos)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=altimetrix-uploads

# Dev : mettre à true pour bypass abonnement (Mission Planner, etc.)
# Tu peux aussi utiliser ?dev=1 dans l'URL pour un bypass par session
NEXT_PUBLIC_DEV_BYPASS=true
